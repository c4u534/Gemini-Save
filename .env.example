# Google Cloud Configuration
GOOGLE_CLOUD_PROJECT="your-gcp-project-id"
GOOGLE_CLOUD_LOCATION="us-central1"

# Application Configuration
PORT=8080

# Default Google Drive File ID used for context storage
# Used if the client does not provide a 'contextFileId' in the request body.
DEFAULT_CONTEXT_FILE_ID="your-default-drive-file-id"
